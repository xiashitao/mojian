# DeepSeek API Key (for LLM arbitration)
DEEPSEEK_API_KEY=sk-...

# Frontend: set true to test streaming chat UI without backend
VITE_MOCK_CHAT=false

# DeepSeek API config (optional)
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# SQLite database path (optional, defaults to web/charts.db)
DATABASE_PATH=charts.db

# JWT config — generate a strong secret for production
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_DAYS=30

# Set to false in local development (HTTP). Must be true in production (HTTPS).
COOKIE_SECURE=false
