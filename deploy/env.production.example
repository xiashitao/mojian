# 生产环境变量 —— 复制为 web/.env（已 gitignore，绝不入库）。
# 后端从 web/.env 读取（config.py）。

# ── 安全 ──────────────────────────────────────────────
# 强随机密钥：openssl rand -hex 32 生成后填这里。变了所有人 cookie 失效。
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
# 线上是 HTTPS（Caddy），必须 true，否则 Secure cookie 不带 → 401。
COOKIE_SECURE=true

# ── LLM（美西/美东：用美国托管、说 OpenAI 协议的，避免跨太平洋打 DeepSeek）──
# 主模型（咨询主回复 + 仲裁）。示例用 Together 跑 DeepSeek-V3；Groq/Fireworks/OpenAI 同理。
LLM_BASE_URL=https://api.together.xyz/v1
LLM_API_KEY=CHANGE_ME
LLM_MODEL=deepseek-ai/DeepSeek-V3

# 快模型（路由/抽取/追问等杂活，走更便宜更快的）。不填则回退到主模型。
FAST_LLM_BASE_URL=https://api.together.xyz/v1
FAST_LLM_API_KEY=CHANGE_ME
FAST_LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ── 邮箱验证码登录 ─────────────────────────────────────
# 开发/未接邮箱时用 log（验证码打到后端日志，本地能拿到码走通流程）。
# 接通腾讯云邮件推送后改为 smtp，并填下面 SMTP（在邮件推送控制台「发信设置」拿）。
EMAIL_PROVIDER=log
EMAIL_FROM=Kairos <noreply@你的发信域名>
# SMTP_HOST=smtp.qcloudmail.com
# SMTP_PORT=465
# SMTP_SSL=true
# SMTP_USER=你的发信地址
# SMTP_PASSWORD=邮件推送生成的SMTP密码

# ── 备注 ──────────────────────────────────────────────
# - 换模型后务必跑 eval 确认质量没掉：PYTHONPATH=. web/.venv/bin/python -m web.backend.eval.run
# - 若坚持用 DeepSeek（仅当服务器其实离中国近，如新加坡/日本），改成：
#     LLM_BASE_URL=https://api.deepseek.com   LLM_MODEL=deepseek-chat   LLM_API_KEY=...
# - 其余设置（数据库路径等）有合理默认，按需再覆盖。
